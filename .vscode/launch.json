{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Frontend (Web)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-scss",
            "program": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/MyTestApp.Web/MyTestApp.Web.csproj"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "serverReadyAction": {
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s",
                "action": "openExternally"
            }
        },
        {
            "name": "Launch Backend (ApiService)",
            "type": "coreclr",
            "request": "launch",
            "program": "dotnet",
            "args": [
                "run",
                "--project",
                "${workspaceFolder}/MyTestApp.ApiService/MyTestApp.ApiService.csproj"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ],
    "compounds": [
        {
            "name": "Launch Frontend and Backend",
            "configurations": [
                "Launch Frontend (Web)",
                "Launch Backend (ApiService)"
            ]
        }
    ]
}