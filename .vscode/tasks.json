{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-scss",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "if (!(Test-Path node_modules)) { npm install }; npx sass MyTestApp.Web/wwwroot/styles.scss MyTestApp.Web/wwwroot/styles.css"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}